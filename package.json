{
  "name": "keystone-app",
  "version": "1.0.1",
  "private": true,
  "scripts": {
    "dev": "keystone dev",
    "start": "keystone start",
    "build": "keystone build",
    "deploy": "NODE_ENV=production npm ci && pm2 stop api.log.football && NODE_ENV=production npm run build && pm2 start process.config.js",
    "postinstall": "keystone postinstall --fix",
    "scrape": "tsx scripts/scraper/index.ts",
    "offseason": "tsx scripts/offseason/index.ts",
    "free-agency": "tsx scripts/free_agency/index.ts",
    "import-contracts": "tsx scripts/contracts/index.ts",
    "test:build": "rm -f schema.prisma && dotenv -e .env.test -- keystone build --no-ui",
    "test": "tsc --noEmit && npm run test:build && jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@keystone-6/auth": "^9.0",
    "@keystone-6/core": "^7.0",
    "dotenv": "^17.4.2",
    "nodemailer": "^9.0.0",
    "tsx": "^4.9.4"
  },
  "engines": {
    "node": "^22"
  },
  "devDependencies": {
    "@swc/core": "^1.15.46",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/nodemailer": "^8.0.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.0.0",
    "typescript": "^7.0.0"
  }
}
